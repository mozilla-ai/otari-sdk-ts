# Copy this file to `.env` and fill in your values.
# Then run your script with:  node --env-file=.env your-script.js

# --- Pick ONE of the following auth methods ---

# Platform mode (Bearer): use a project/platform token from otari.ai, or any
# gateway you've connected to otari.ai via OTARI_AI_TOKEN. The SDK defaults
# to https://gateway.otari.ai when a platform token is set, so no base URL
# is needed for the hosted gateway.
GATEWAY_PLATFORM_TOKEN=tk_your_project_token

# API-key mode (Otari-Key header): use a key issued by a standalone self-hosted
# gateway (e.g. /v1/keys or the bootstrap key printed at startup). Requires
# GATEWAY_API_BASE since the SDK has no default for self-hosted gateways.
# GATEWAY_API_KEY=your-gateway-api-key

# Base URL of the gateway. Only required for self-hosted gateways. Override
# this if you've connected your own gateway to otari.ai instead of using
# the hosted https://gateway.otari.ai.
# GATEWAY_API_BASE=http://localhost:8000
