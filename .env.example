# Copy this file to `.env` and fill in your values.
# Then run your script with:  node --env-file=.env your-script.js

# API token from https://otari.ai/organization-settings/api-tokens. The SDK
# defaults to https://api.otari.ai when this is set, so no base URL is needed
# for the hosted gateway.
OTARI_AI_TOKEN=tk_your_api_token

# --- Self-hosted gateway only (uncomment if you run your own gateway) ---

# Where you've deployed the gateway (e.g. http://localhost:8000).
# GATEWAY_API_BASE=http://localhost:8000

# API key issued by your self-hosted gateway (e.g. /v1/keys or the bootstrap
# key printed at startup).
# GATEWAY_API_KEY=your-gateway-api-key
